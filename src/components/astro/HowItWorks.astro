---
const steps = [
  {
    number: 1,
    title: 'Avaliação de Saúde',
    description: 'Compartilhe seu histórico clínico e objetivos em nosso formulário seguro. Leva menos de 5 minutos.',
    image: '/passo1.webp'
  },
  {
    number: 2,
    title: 'Análise do Perfil',
    description: 'Um especialista revisará seu perfil e decidirá se o acompanhamento é indicado para você.',
    image: '/passo2.webp'
  },
  {
    number: 3,
    title: 'Acompanhamento Contínuo',
    description: 'Se aprovado, receba seu plano personalizado com suporte contínuo da nossa equipe.',
    image: '/caixa.webp'
  }
];
---

<section class="w-full py-16 lg:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 md:px-8 lg:px-12">
    <!-- Header -->
    <div class="text-center mb-16 space-y-4">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-sans font-light text-navy-800">
        Como funciona a Slima
      </h2>
      <p class="text-navy-800/70 font-sans text-lg md:text-xl max-w-2xl mx-auto">
        Inicie sua jornada de saúde sem sair de casa e sem burocracia.
      </p>
    </div>

    <!-- Steps Grid -->
    <div class="flex md:grid md:grid-cols-3 gap-4 md:gap-8 overflow-x-auto md:overflow-visible snap-x snap-mandatory pt-8 pb-12 md:pb-0 -mx-4 px-4 md:mx-0 md:px-0 scrollbar-hide [&::-webkit-scrollbar]:hidden [-ms-overflow-style:'none'] [scrollbar-width:'none']">
      {steps.map((step) => (
        <div
          class="relative flex flex-col items-center text-center p-8 rounded-2xl bg-[#F7FBFF] border border-blue-50/50 hover:shadow-lg transition-all duration-300 group w-[80vw] max-w-[340px] md:w-auto md:max-w-none snap-center flex-shrink-0"
        >
          <!-- Number Badge -->
          <div class="absolute -top-5 w-10 h-10 rounded-full bg-white shadow-[0_2px_8px_rgba(0,0,0,0.08)] flex items-center justify-center text-lg font-bold text-navy-800 font-sans border border-gray-50">
            {step.number}
          </div>

          <!-- Visual Area -->
          <div class="h-64 w-full flex items-center justify-center mb-6 mt-4">
            <div class="transform transition-transform duration-500 group-hover:scale-105">
              <img src={step.image} alt={step.title} loading="lazy" class="w-auto h-52 object-contain" />
            </div>
          </div>

          <!-- Text Content -->
          <h3 class="text-xl font-bold text-navy-800 mb-3 font-sans">
            {step.title}
          </h3>
          <p class="text-navy-800/70 font-sans leading-relaxed text-sm md:text-base">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
